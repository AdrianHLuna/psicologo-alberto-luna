{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/enfermedades/layout,_N_T_/enfermedades/[slug]/layout,_N_T_/enfermedades/[slug]/page,_N_T_/enfermedades/trastorno-obsesivo-compulsivo"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/enfermedades/$d$slug/__PAGE__",
    "/enfermedades/$d$slug",
    "/enfermedades",
    "/_index",
    "/_head"
  ]
}